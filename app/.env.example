PORT=3000
MONGO_URL=mongodb://127.0.0.1:27017/mailcode
REDIS_URL=redis://127.0.0.1:6379

JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=10m
ADMIN_JWT_EXPIRES_IN=1h
ADOBE_JWT_EXPIRES_IN=10m
CODE_TTL_SECONDS=600

DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=change_this_password

MAIL_DOMAINS=889100.xyz
MAIL_HOST=imap.example.com
MAIL_PORT=993
MAIL_SECURE=true
MAIL_USER=user@example.com
MAIL_PASS=replace_with_mail_password
MAIL_LISTENER_ENABLED=true
MAIL_SCAN_WINDOW_MINUTES=5
MAIL_SCAN_INTERVAL_SECONDS=30
