PORT=3000
MONGO_URL=mongodb://127.0.0.1:27017/mailcode
REDIS_URL=redis://127.0.0.1:6379

JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=10m
ADMIN_JWT_EXPIRES_IN=1h
ADOBE_JWT_EXPIRES_IN=10m
CODE_TTL_SECONDS=300

DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=change_this_password

# 多域名示例：[{"domain":"a.com","verificationCodeUrl":"mail.a.com"},{"domain":"b.com","verificationCodeUrl":"mail.b.com"},{"domain":"c.com","verificationCodeUrl":"www.c.com"}]
MAIL_DOMAIN_CONFIG=[{"domain":"889100.xyz","verificationCodeUrl":"https://www.cloudyard.cn"}]
MAIL_HOST=imap.example.com
MAIL_PORT=993
MAIL_SECURE=true
MAIL_USER=user@example.com
MAIL_PASS=replace_with_mail_password
MAIL_PROXY_ENABLED=false
# 代理示例：socks5://user:pass@proxy-host:1080
# 如果使用纯 socks5 代理，也可以写成：socks5://proxy-host:1080
MAIL_PROXY_URL=
MAIL_LISTENER_ENABLED=true
MAIL_SCAN_WINDOW_MINUTES=5
MAIL_SCAN_INTERVAL_SECONDS=30

SOFTWARE_FILE_ROOT=./software-files
SOFTWARE_MAX_UPLOAD_MB=500
SOFTWARE_IMPORT_MAX_MB=1024
SOFTWARE_IMPORT_TIMEOUT_SECONDS=300
SOFTWARE_ALLOWED_EXTENSIONS=exe,msi,zip,7z,rar,apk,dmg,pkg,iso,pdf
